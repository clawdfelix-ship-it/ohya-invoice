# OHA Invoice - Environment Variables for Vercel

# Neon PostgreSQL Database URL
# Get this from https://console.neon.tech → your project → Connection Details
DATABASE_URL="postgresql://username:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

# DocRaptor API Key (for PDF generation with Japanese/Chinese support)
# Get this from https://docraptor.com → Account → API Keys
# Free tier: 100 documents/month
DOCRAPTER_API_KEY="your_docraptor_api_key_here"
